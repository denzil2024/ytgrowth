{
  "manifest_version": 3,
  "name": "YTGrowth",
  "version": "0.1.8",
  "description": "Live SEO score, hidden tags, view velocity, engagement, and revenue estimate on every YouTube video.",
  "icons": {
    "16":  "icon.svg",
    "32":  "icon.svg",
    "48":  "icon.svg",
    "128": "icon.svg"
  },
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://ytgrowth.io/*",
    "https://*.ytgrowth.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["page-bridge.js"],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js", "search-overlay.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2", "icon.svg"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],
  "action": {
    "default_title": "YTGrowth",
    "default_icon": {
      "16":  "icon.svg",
      "32":  "icon.svg",
      "48":  "icon.svg",
      "128": "icon.svg"
    }
  }
}
